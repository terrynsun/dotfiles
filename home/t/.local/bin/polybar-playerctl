#!/bin/bash

STATUS=$(playerctl status)
if [[ $STATUS == "Playing" ]]; then
    SONG=$(playerctl metadata \
        | grep --color=never 'title' \
        | sed -E 's/.*title +//')
    ARTIST=$(playerctl metadata \
        | grep --color=never 'artist' \
        | sed -E 's/.*artist +//')
    echo $SONG [$ARTIST]
else
    echo $STATUS
fi
